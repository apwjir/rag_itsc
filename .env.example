# -----------------------------
# RAG / Knowledge Base (Qdrant)
# -----------------------------
STIX_FILE_PATH=data/enterprise-attack.json
VECTOR_DIMS=3072
COLLECTION_NAME=your_collection_name

# -----------------------------
# Embedding Provider (required)
# NOTE: current backend uses OpenAI embeddings even if generation uses Ollama/Groq/etc.
# -----------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=

# -----------------------------
# Generation Model Selection
# Must match display_name in app/services/api_models.json
# Example options:
# - GPT OSS 120B Ollama
# - GPT OSS 120B
# - Llama 4 Scout 17B Instruct
# - Gemini 3 Pro
# - Claude Sonnet 4.5
# - GPT-4.1
# -----------------------------
GENERATION_MODEL_DISPLAY_NAME="GPT OSS 120B Ollama"

# Provider API keys (fill only what you use)
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (used when provider is Ollama)
OLLAMA_BASE_URL=http://ollama:11434

# -----------------------------
# Elasticsearch
# -----------------------------
ES_URL=http://es01:9200
ES_INDEX=your_elasticsearch_index_name

# -----------------------------
# Qdrant
# -----------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# -----------------------------
# PostgreSQL
# -----------------------------
POSTGRES_PORT=5432
POSTGRES_DB=incident_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

POSTGRES_APP_USER=admin
POSTGRES_APP_PASSWORD=your_app_password_here

DATABASE_URL=postgresql://admin:your_app_password_here@postgres:5432/incident_management

# -----------------------------
# Auth / Security
# -----------------------------
SECRET_KEY=your_jwt_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -----------------------------
# CORS
# -----------------------------
ALLOWED_ORIGINS=http://dashboard:5173,https://localhost:5173,http://localhost:5173

# -----------------------------
# Seed Admin User
# -----------------------------
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# -----------------------------
# Runtime
# -----------------------------
TZ=Asia/Bangkok
